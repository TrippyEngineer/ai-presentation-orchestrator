# ────────────────────────────────────────────────────────────────────
# .env.example  ·  AI Presentation Orchestrator
# Copy this file to .env and fill in your values.
# ────────────────────────────────────────────────────────────────────

# ── LLM ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── HEYGEN (AI Avatar voice synthesis) ──────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ── GOOGLE SLIDES ────────────────────────────────────────────────────
# The ID is in your Slides URL:
# https://docs.google.com/presentation/d/THIS_IS_THE_ID/edit
GOOGLE_SLIDES_PRESENTATION_ID=

# ── n8n WEBHOOKS ─────────────────────────────────────────────────────
N8N_WEBHOOK_EMAIL=http://localhost:5678/webhook/email-demo
N8N_WEBHOOK_MEETING=http://localhost:5678/webhook/meeting-demo
N8N_WEBHOOK_RESEARCH=http://localhost:5678/webhook/research-demo

# ── SLACK ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── PRESENTER IDENTITY (used in Claude prompts) ──────────────────────
PRESENTER_NAME=Your Name
PRESENTER_ROLE=your role
ORGANIZATION=Your Organization
AUDIENCE_CONTEXT=Programme managers, M&E staff, country office teams
DOMAIN_CONTEXT=public health programmes, field teams, donor reporting

# ── PRESENTATION ─────────────────────────────────────────────────────
PPTX_FILE=presentation.pptx
TOTAL_SLIDES=17
DEMO_SLIDES=8:email,10:meeting,12:research

# ── VOICE (Edge TTS fallback — free, no key needed) ──────────────────
TTS_VOICE=en-US-AndrewNeural
TTS_RATE=-3%
# Options: heygen | edgetts
VOICE_ENGINE=edgetts
