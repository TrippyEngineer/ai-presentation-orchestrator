        "jsCode": "// Get all emails from the sheet\nconst attendees = $input.all();\nconst emails = attendees\n  .map(item => item.json.Email)\n  .filter(email => email && email.includes('@'))\n  .join(', ');\n\n// Also carry forward the parsed meeting data\nconst meetingData = $('Parse JSON').item.json;\n\nreturn [{\n  json: {\n    ...meetingData,\n    recipient_emails: emails\n  }\n}];\n"
