    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a meeting analyst.\n\nAnalyze this meeting transcript carefully.\n\nMeeting Name: {{ $json[\"Meeting Name\"] }}\nTranscript: {{ $json[\"Meeting Transcript\"] }}\n\nRespond ONLY in valid JSON, no other text:\n{\n  \"meeting_name\": \"the meeting name\",\n  \"date_processed\": \"today\",\n  \"total_action_items\": 0,\n  \"action_items\": [\n    {\n      \"action\": \"what needs to be done\",\n      \"owner\": \"person responsible or UNCLEAR\",\n      \"deadline\": \"deadline or NOT SPECIFIED\",\n      \"priority\": \"HIGH or MEDIUM or LOW\"\n    }\n  ],\n  \"decisions_made\": [\"decision 1\"],\n  \"unclear_ownership\": [\"action items where nobody was assigned\"],\n  \"biggest_risk\": \"the one thing most likely to fall through\",\n  \"follow_up_email_subject\": \"subject line\",\n  \"follow_up_email_body\": \"complete ready to send email text. Always end the email with this exact signature:\\n\\nBest regards,\\n[YOUR NAME]\\nDigital Health | AI | MedTech\",\n  \"slack_summary\": \"3 bullet points each under 15 words\"\n}\n",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        0,
        -96
      ],
      "id": "3197fc31-2c97-4295-8f1d-f7958d5964ba",
      "name": "Claude Analysis"
    },
    {
      "parameters": {
        "jsCode": "// Get raw Claude output\nconst rawText = $input.first().json.text;\n\n// Step 1: Extract ONLY the JSON object using regex (ignore everything else)\nconst jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  throw new Error('No JSON object found in Claude response');\n}\n\nlet jsonString = jsonMatch[0];\n\n// Step 2: Replace literal newlines INSIDE string values only\n// This replaces actual line breaks with \\n escape\njsonString = jsonString\n  .replace(/(\"(?:[^\"\\\\]|\\\\.)*\")/g, (match) => {\n    return match\n      .replace(/\\n/g, '\\\\n')\n      .replace(/\\r/g, '\\\\r')\n      .replace(/\\t/g, '\\\\t');\n  });\n\n// Step 3: Parse\nconst parsed = JSON.parse(jsonString);\n\nreturn [{ json: parsed }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
